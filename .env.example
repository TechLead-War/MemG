# MemG Environment Variables
# Copy this file to .env and fill in the values you need.
# Only set the providers you actually use.

# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=
AZURE_OPENAI_API_KEY=

# ── Embedding Providers ────────────────────────────────────────
# OpenAI, Gemini, Azure, Together use the same keys as above.
HF_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# ── MemG Overrides (optional, config file is preferred) ───────
# MEMG_DEBUG=1
# MEMG_LLM_PROVIDER=openai
# MEMG_EMBED_PROVIDER=local
# MEMG_RECALL_FACTS_LIMIT=100
# MEMG_RECALL_THRESHOLD=0.10
# MEMG_SESSION_TIMEOUT=30m
# MEMG_WORKING_MEMORY_TURNS=20
# MEMG_MEMORY_TOKEN_BUDGET=4000
# MEMG_SUMMARY_TOKEN_BUDGET=1000
# MEMG_CONSCIOUS_CACHE_TTL=30s
# MEMG_RECALL_EMBEDDINGS_LIMIT=100000
# MEMG_MAX_RECALL_CANDIDATES=10000
